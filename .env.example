# ── Required ──────────────────────────────────────────────────────────────────

# Absolute path to the target repo on the host machine
AE_TARGET_REPO_PATH=/absolute/path/to/your-repo

# GitHub personal access token with repo + workflow scopes
GH_TOKEN=

# ── Repo config ───────────────────────────────────────────────────────────────
# Copy config/repos/template.yaml, fill it in for your repo, and point here.
# AE_REPO_CONFIG_HOST_PATH mounts your config at /engine/config/repo.yaml.
AE_REPO_CONFIG_HOST_PATH=/absolute/path/to/your-repo-config.yaml

# ── Optional overrides ────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=
AE_STACK_ID=
AE_MODE=loop
AE_LOOP_INTERVAL_SECONDS=300
AE_STATE_DIR=/engine/state
AE_DASHBOARD_PORT=4700
AE_DEFAULT_LOG_LEVEL=info

# Strongly recommended — without it, the dashboard (including its pause/
# resume/service-control endpoints) is unauthenticated for anyone who can
# reach the port. Generate one with `openssl rand -hex 32`.
# AE_DASHBOARD_TOKEN=

# Codex CLI persists ChatGPT login state inside the named `codex-home` volume.
# GitHub CLI auth persists inside the named `gh-config` volume.
# When using a remote Docker context, AE_TARGET_REPO_PATH must be a path on that remote host.

# Local model lane (optional — only needed if config enables local lane)
# AE_LOCAL_MODEL_IMAGE=ollama/ollama:latest
# AE_LOCAL_MODEL_CACHE_PATH=/absolute/path/to/ollama-cache

# openai_compatible lane (optional — only needed if your config enables one).
# Set the env var named by that lane's api_key_env, e.g. for the documented
# Featherless.ai example lane in config/repos/template.yaml:
# FEATHERLESS_API_KEY=
# A key entered through the dashboard's settings panel always takes priority
# over this — this is just the Docker-level default for a fresh deployment.
